import os
import time
import re
import csv
from pyhwpx import Hwp

hwp = Hwp()
all_reports = []

# 경로 설정
target_folder = r"X:\3. 예결산 실태점검\2025\작업"

file_list = [
    os.path.join(target_folder, f) 
    for f in os.listdir(target_folder) 
    if f.endswith(('.hwp', '.hwpx')) and not f.startswith('~$')
]

print(f"검색된 파일 개수: {len(file_list)}개")

# 데이터 추출을 위한 정규표현식
univ_name_re = re.compile(r'대학명\s*\(법인명\)\s*[:：]\s*(.+)')
finding_title_re = re.compile(r'^(\d+)\.\s+(.+)$')
key_re = re.compile(r'^(?:[^가-힣A-Za-z0-9\s]+)?\s*(시정구분|점검항목|관련규정|점검내용|점검절차|점검결과\s*발견사항|점검결과|개선방안)(?:\s*[:：]\s*(.+))?$')

for file in file_list:
    file_name = os.path.basename(file)
    print(f"진행 중: {file_name}")
    
    try:
        hwp.open(file)
        raw_data = hwp.GetTextFile("TEXT", "")
        
        full_text = ""
        if isinstance(raw_data, str):
            full_text = raw_data
        elif isinstance(raw_data, tuple):
            full_text = next((item for item in raw_data if isinstance(item, str)), "")
        
        if not full_text:
            hwp.close()
            continue
            
        lines = full_text.split('\r\n')
        
        report_data = {
            "파일명": file_name,
            "법인명": "미상",
            "대학명": "미상",
            "세부내역": []
        }
        
        state = "INIT"
        expected_num = 1
        current_finding = None
        current_key = None

        for line in lines:
            line_clean = re.sub(r'&#\d+;', '', line.strip()).strip()
            if not line_clean: continue
            
            if state in ["INIT", "GENERAL"]:
                m_univ = univ_name_re.search(line_clean)
                if m_univ:
                    raw_name = m_univ.group(1).strip()
                    if '(' in raw_name and raw_name.endswith(')'):
                        univ_part, found_part = raw_name.rsplit('(', 1)
                        report_data["대학명"] = univ_part.strip()
                        report_data["법인명"] = found_part.replace(')', '').strip()
                    else:
                        report_data["대학명"] = raw_name
                    continue

            line_no_space = line_clean.replace(" ", "")
            if "항목별점검결과요약" in line_no_space:
                state = "SUMMARY"
                continue
            elif "점검결과및개선과제세부내역" in line_no_space:
                state = "DETAIL"
                continue

            if state == "DETAIL":
                m_title = finding_title_re.match(line_clean)
                if m_title and int(m_title.group(1)) == expected_num:
                    if current_finding:
                        report_data["세부내역"].append(current_finding)
                        
                    current_finding = {
                        "연번": expected_num,
                        "지적사항": m_title.group(2).strip()
                    }
                    current_key = None
                    expected_num += 1
                    continue
                
                if current_finding:
                    m_key = key_re.match(line_clean)
                    if m_key:
                        key = m_key.group(1).replace(" ", "")
                        
                        if "점검결과" in key:
                            key = "점검결과 발견사항"
                        elif key == "점검절차":  
                            key = "점검내용"
                            
                        if m_key.group(2): 
                            val = m_key.group(2).strip()
                            current_finding[key] = val
                            current_key = key
                        else: 
                            current_key = key
                            current_finding[current_key] = []
                    else:
                        if current_key:
                            if isinstance(current_finding[current_key], list):
                                current_finding[current_key].append(line_clean)
                            elif isinstance(current_finding[current_key], str):
                                current_finding[current_key] += f"\n{line_clean}"

        if current_finding:
            report_data["세부내역"].append(current_finding)

        all_reports.append(report_data)
        hwp.close()
        
    except Exception as e:
        print(f"오류 발생({file_name}): {e}")
        try: hwp.quit()
        except: pass
        time.sleep(1)
        hwp = Hwp()
        continue

# CSV 파일 저장
if all_reports:
    csv_save_path = os.path.join(target_folder, "실태점검_결과보고서_요약.csv")
    
    headers = [
        "학교법인명", "학교명", "연번", "지적사항",
        "시정구분", "점검항목", "관련규정", "점검내용", "점검결과 발견사항", "개선방안"
    ]
    
    with open(csv_save_path, mode="w", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=headers)
        writer.writeheader()
        
        for report in all_reports:
            corp_name = report.get("법인명", "미상")
            univ_name = report.get("대학명", "미상")
            
            for item in report.get("세부내역", []):
                
                def format_value(val):
                    # 1. 텍스트를 먼저 하나의 문장으로 병합
                    if isinstance(val, list):
                        text = "\n".join(val)
                    elif isinstance(val, str):
                        text = val
                    else:
                        text = ""
                        
                    # 2. 전체 문장의 맨 앞부분 검사 (공백 제거 후 판단)
                    text_stripped = text.lstrip()
                    if text_stripped.startswith('-') or text_stripped.startswith('­'):
                        return "'" + text_stripped
                    return text.strip()

                row = {
                    "학교법인명": corp_name,
                    "학교명": univ_name,
                    "연번": item.get("연번", ""),
                    "지적사항": item.get("지적사항", ""),
                    "시정구분": format_value(item.get("시정구분")),
                    "점검항목": format_value(item.get("점검항목")),
                    "관련규정": format_value(item.get("관련규정")),
                    "점검내용": format_value(item.get("점검내용")),
                    "점검결과 발견사항": format_value(item.get("점검결과 발견사항")),
                    "개선방안": format_value(item.get("개선방안"))
                }
                writer.writerow(row)
                
    print(f"\n취합 완료. 총 {len(all_reports)}개 기관의 데이터를 CSV 파일로 저장했어.")
else:
    print("\n데이터를 찾지 못했어. 관리자 권한으로 실행해 봐.")

hwp.quit()
