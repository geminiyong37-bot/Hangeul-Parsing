import os
from pyhwpx import Hwp

def parse_hwp_basic(folder_path):
    hwp = Hwp()
    
    file_list = [
        os.path.join(folder_path, f) 
        for f in os.listdir(folder_path) 
        if f.endswith(('.hwp', '.hwpx')) and not f.startswith('~$')
    ]
    
    parsed_data = []

    for file in file_list:
        file_name = os.path.basename(file)
        print(f"파싱 진행 중: {file_name}")
        
        try:
            hwp.open(file)
            raw_data = hwp.GetTextFile("TEXT", "")
            
            if isinstance(raw_data, tuple):
                full_text = next((item for item in raw_data if isinstance(item, str)), "")
            else:
                full_text = str(raw_data)
            
            if not full_text:
                hwp.close()
                continue
            
            lines = full_text.split('\r\n')
            file_content = []
            
            for line in lines:
                line_clean = line.strip()
                if not line_clean: 
                    continue
                file_content.append(line_clean)
            
            parsed_data.append({
                "파일명": file_name,
                "내용_라인수": len(file_content),
                "전체텍스트": file_content 
            })
            
            hwp.close()
            
        except Exception as e:
            print(f"오류 발생({file_name}): {e}")
            try: hwp.quit()
            except: pass
            hwp = Hwp()
            continue
            
    hwp.quit()
    return parsed_data

def save_to_markdown(parsed_data, save_path):
    """
    파싱된 데이터를 마크다운 형식으로 변환하여 파일로 저장하는 함수.
    """
    with open(save_path, "w", encoding="utf-8") as f:
        f.write("# HWP 파싱 결과 요약\n\n")
        
        for data in parsed_data:
            f.write(f"## 📄 파일명: {data['파일명']}\n")
            f.write(f"- **총 추출 라인 수**: {data['내용_라인수']}줄\n\n")
            f.write("### 📝 본문 내용\n")
            
            # 본문 내용을 코드 블록 또는 인용구로 처리하여 가독성 확보
            f.write("```text\n")
            for line in data['전체텍스트']:
                f.write(f"{line}\n")
            f.write("```\n\n")
            f.write("---\n\n")

