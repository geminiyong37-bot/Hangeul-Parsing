import os
import zipfile
import xml.etree.ElementTree as ET
import json
import tempfile
from pyhwpx import Hwp

def extract_text_from_hwpx(hwpx_path):
    """
    HWPX 파일에서 텍스트와 '표(Table)'를 마크다운 구조로 완벽히 추출하는 함수
    """
    file_content = []
    try:
        with zipfile.ZipFile(hwpx_path, 'r') as zf:
            xml_files = [f for f in zf.namelist() if f.startswith('Contents/section') and f.endswith('.xml')]
            xml_files.sort()
            
            for xml_file in xml_files:
                content = zf.read(xml_file)
                tree = ET.fromstring(content)
                
                # 1. 태그명에서 복잡한 네임스페이스(namespace) 제거 (탐색 최적화)
                for elem in tree.iter():
                    elem.tag = elem.tag.split('}')[-1]
                
                # 2. 표(tbl)를 찾아 마크다운(Markdown) 테이블 포맷으로 변환
                for tbl in tree.findall('.//tbl'):
                    table_md = []
                    rows = tbl.findall('.//tr')
                    
                    for i, tr in enumerate(rows):
                        row_cells = []
                        for tc in tr.findall('.//tc'):
                            # 셀 내부의 텍스트를 모으고, 표가 깨지지 않게 줄바꿈을 띄어쓰기로 치환
                            cell_texts = [t.text for t in tc.findall('.//t') if t.text]
                            cell_text = " ".join(cell_texts).replace('\n', ' ').replace('\r', '').strip()
                            row_cells.append(cell_text)
                            
                        # 마크다운 행 추가
                        table_md.append("| " + " | ".join(row_cells) + " |")
                        
                        # 첫 번째 행(헤더) 밑에 구분선(---) 추가
                        if i == 0:
                            sep = "| " + " | ".join(["---"] * len(row_cells)) + " |"
                            table_md.append(sep)
                    
                    # 완성된 마크다운 표 문자열
                    md_string = "\n" + "\n".join(table_md) + "\n"
                    
                    # 기존 표의 복잡한 하위 태그들을 모두 지우고, 일반 텍스트 태그(<t>)로 위장시킴
                    tbl.clear()
                    tbl.tag = 't'
                    tbl.text = md_string

                # 3. 변환된 표를 포함하여, 문서 내의 모든 단락(p) 텍스트를 순서대로 추출
                for p in tree.findall('.//p'):
                    para_text = ""
                    for t in p.findall('.//t'):
                        if t.text:
                            para_text += t.text
                            
                    line_clean = para_text.strip()
                    if line_clean:
                        file_content.append(line_clean)
                        
    except Exception as e:
        print(f"HWPX 파싱 및 표 추출 오류({os.path.basename(hwpx_path)}): {e}")
        
    return file_content

def parse_documents(folder_path):
    """HWP 및 HWPX 파싱 통합 프로세스"""
    file_list = [
        os.path.join(folder_path, f) 
        for f in os.listdir(folder_path) 
        if f.endswith(('.hwp', '.hwpx')) and not f.startswith('~$')
    ]
    
    parsed_data = []
    hwp = None
    
    has_hwp = any(f.endswith('.hwp') for f in file_list)
    if has_hwp:
        try:
            hwp = Hwp()
        except Exception as e:
            print(f"한글 프로그램 연동 실패: {e}\n(HWP 파일은 건너뜁니다.)")

    for file in file_list:
        file_name = os.path.basename(file)
        print(f"🔄 파싱 진행 중: {file_name}")
        
        file_content = []
        
        # 1. HWPX 파일은 직접 추출
        if file.endswith('.hwpx'):
            file_content = extract_text_from_hwpx(file)
            
        # 2. HWP 파일은 백그라운드에서 임시 HWPX로 변환 후 표까지 완벽히 추출
        elif file.endswith('.hwp') and hwp is not None:
            temp_path = ""
            try:
                hwp.open(file)
                # 임시 hwpx 파일 경로 생성
                temp_fd, temp_path = tempfile.mkstemp(suffix='.hwpx')
                os.close(temp_fd) 
                
                # OLE를 통해 HWPX 포맷으로 저장 (표 구조 보존을 위해)
                hwp.SaveAs(temp_path, "HWPX")
                hwp.close()
                
                # 변환된 HWPX 파싱
                file_content = extract_text_from_hwpx(temp_path)
                
            except Exception as e:
                print(f"❌ HWP 변환 파싱 오류({file_name}): {e}")
                try: hwp.quit()
                except: pass
                hwp = Hwp()
            finally:
                # 파싱이 끝나면 임시 파일 삭제
                if os.path.exists(temp_path):
                    os.remove(temp_path)
        
        if file_content:
            parsed_data.append({
                "파일명": file_name,
                "내용_라인수": len(file_content),
                "전체텍스트": file_content 
            })
            
    if hwp is not None:
        try: hwp.quit()
        except: pass
        
    return parsed_data

def save_to_markdown(parsed_data, save_path):
    with open(save_path, "w", encoding="utf-8") as f:
        f.write("# HWP & HWPX 파싱 결과 요약\n\n")
        for data in parsed_data:
            f.write(f"## 📄 파일명: {data['파일명']}\n")
            f.write(f"- **총 추출 라인 수**: {data['내용_라인수']}줄\n\n")
            f.write("### 📝 본문 내용\n")
            f.write("```text\n")
            for line in data['전체텍스트']:
                f.write(f"{line}\n")
            f.write("```\n\n---\n\n")

def save_to_json(parsed_data, save_path):
    vector_data = []
    for data in parsed_data:
        vector_data.append({
            "source": data["파일명"],
            "total_lines": data["내용_라인수"],
            "content": "\n".join(data["전체텍스트"])
        })
        
    with open(save_path, "w", encoding="utf-8") as f:
        json.dump(vector_data, f, ensure_ascii=False, indent=2)

